# ── Local dev ──────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ── Production (Render / Railway / Docker) ─────────────────
# CORS_ORIGIN=https://your-app.vercel.app
# PORT is set automatically by the host (Render/Railway)

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_PROJECT_ID=your_project_id_here

# Optional: proxy URL if OpenAI is blocked in your region
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Comma-separated image models to try in order
# OPENAI_IMAGE_MODELS=gpt-image-1.5,gpt-image-1,dall-e-2

# Request timeout in ms (default 300000 — keep high for image generation)
# OPENAI_TIMEOUT_MS=300000

# Product photo background removal before OpenAI edit (default: enabled)
# PRODUCT_BG_REMOVAL_ENABLED=true
# Model size: small (fast) | medium | large (best quality)
# PRODUCT_BG_REMOVAL_MODEL=small

# Image upscaling after generation (default: enabled, 2x)
# IMAGE_UPSCALE_ENABLED=true
# IMAGE_UPSCALE_FACTOR=2
