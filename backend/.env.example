# ── Local dev ──────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ── Production (Render / Railway / Docker) ─────────────────
# CORS_ORIGIN=https://snap-feed-ai.vercel.app
# PORT is set automatically by the host (Render/Railway)

# OpenAI — used for GPT-4o-mini (prompt optimization, vision analysis, hashtags)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_PROJECT_ID=your_project_id_here

# Optional: vision model for product/clothing analysis (default gpt-4o-mini — works in more regions than gpt-4o)
# OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: proxy URL if OpenAI is blocked in your region
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Request timeout in ms (default 300000 — keep high for image generation)
# OPENAI_TIMEOUT_MS=300000

# Image upscaling after generation (default: enabled, 2x)
# IMAGE_UPSCALE_ENABLED=true
# IMAGE_UPSCALE_FACTOR=2

# Optional: public API URL for Replicate to fetch user-uploaded try-on photos
# PUBLIC_API_URL=https://snapfeed-ai.onrender.com
# Virtual try-on model (default: latest cuuupid/idm-vton)
# REPLICATE_IDM_VTON_MODEL=cuuupid/idm-vton:0513734a452173b8173e907e3a59d19a36266e55b48528559432bd21c7d7e985
# Text mode (Generate Visual) — nano-banana-2 T2I with flux-2-pro / flux-schnell fallback
REPLICATE_TEXT_IMAGE_MODEL=google/nano-banana-2
# REPLICATE_TEXT_IMAGE_FALLBACK_MODEL=black-forest-labs/flux-2-pro
# REPLICATE_FLUX_SCHNELL_MODEL=black-forest-labs/flux-schnell

# ── Product branch: google/nano-banana-2 native edit (replicate.com/google/nano-banana-2) ──
PRODUCT_BG_REMOVAL_BACKEND=replicate
PRODUCT_PIPELINE_MODE=native
REPLICATE_NANO_BANANA_MODEL=google/nano-banana-2
REPLICATE_NANO_BANANA_FALLBACK_MODEL=black-forest-labs/flux-2-pro
REPLICATE_PRODUCT_IMAGE_FALLBACK_MODEL=black-forest-labs/flux-2-max
# Replicate pricing: 1K $0.067 | 2K $0.101 | 4K $0.151 per output image
NANO_BANANA_RESOLUTION=1K
NANO_BANANA_OUTPUT_FORMAT=png
# Optional Replicate playground features:
# NANO_BANANA_GOOGLE_SEARCH=false
# NANO_BANANA_IMAGE_SEARCH=false
# Force legacy Sharp composite instead of native edit:
# PRODUCT_PIPELINE_MODE=composite
# Пауза между Replicate-вызовами (вырез фона → nano-banana). Нужна при балансе < $5 (burst=1).
REPLICATE_BURST_DELAY_MS=5000
# Try-on: local garment isolation first (saves 1 Replicate call; helps accounts with <$5 credit)
TRYON_BG_REMOVAL_LOCAL_FIRST=true
# Тонкая настройка линии горизонта подиума для Sharp composite (0.55 square / 0.58 story по умолчанию)
# PODIUM_HORIZON_RATIO=0.55
# Stage 3 — Sharp composite (no env; built into imageGeneration.js)
# Deprecated — do NOT use for product branch anymore:
# REPLICATE_PRODUCT_MODEL=black-forest-labs/flux-fill-dev
# Legacy img2img (unused by product branch):
# REPLICATE_FLUX_IMG2IMG_MODEL=black-forest-labs/flux-dev
# Optional: add extra model URLs to the rotation pool (public direct image URLs only — no Pinterest/Instagram)
# Leave unset to auto-rotate verified GitHub IDM-VTON models by gender and age.
# REPLICATE_TRYON_FEMALE_FULLBODY_IMG=https://raw.githubusercontent.com/yisol/IDM-VTON/main/gradio_demo/example/human/00121_00.jpg
# REPLICATE_TRYON_FEMALE_IMG=https://raw.githubusercontent.com/yisol/IDM-VTON/main/gradio_demo/example/human/00034_00.jpg
# REPLICATE_TRYON_MALE_IMG=https://raw.githubusercontent.com/yisol/IDM-VTON/main/gradio_demo/example/human/will1%20(1).jpg
