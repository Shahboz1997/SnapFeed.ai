# ── Local dev ──────────────────────────────────────────────
# Leave empty — Vite proxies /api/* to http://localhost:5000 (see vite.config.ts)
# VITE_API_URL=

# ── Production (Vercel) ────────────────────────────────────
# Optional — production builds fall back to https://snapfeed-ai.onrender.com automatically.
# Set in Vercel → Project → Settings → Environment Variables only if you use a custom API host.
# VITE_API_URL=https://snapfeed-ai.onrender.com

# ── Supabase Auth ──────────────────────────────────────────
# Project Settings → API in Supabase Dashboard
# Use publishable key (sb_publishable_...) or legacy anon key (eyJ...)
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# ── Support / manual payments (until YooKassa) ─────────────
# Email for credit top-up requests (self-employed payments)
# VITE_SUPPORT_EMAIL=supportstratum@gmail.com
